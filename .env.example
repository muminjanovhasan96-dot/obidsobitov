# ------------------------------------------------------------------
#  OBID SOBITOV — environment variables (all OPTIONAL)
#  Copy this file to `.env.local` and fill in the values you have.
#  On Vercel, add the same keys under Project → Settings → Environment Variables.
# ------------------------------------------------------------------

# Telegram notifications — makes concierge requests, orders and newsletter
# sign-ups arrive automatically in the boutique's Telegram.
#   1. @BotFather → /newbot → copy the token
#   2. Get the chat id (e.g. via @userinfobot)
# Until these are set, forms fall back to opening a pre-filled Telegram link.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Analytics — leave blank to disable. Public (client-side) values.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_YANDEX_METRICA_ID=

# Admin panel password (/admin). Default is "7777" — set a strong one here.
ADMIN_PASSWORD=7777
